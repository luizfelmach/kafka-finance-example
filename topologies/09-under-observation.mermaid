flowchart LR
    subgraph Input
        A[transactions.raw]
    end
    subgraph Process
        B[groupByKey]
        C[aggregate: TxHistory<br/>list of amounts]
        D{filter: size >= 5<br/>&& sumLastN(5) > 90% total?}
        E[toStream]
        F[map: to FraudAlert]
    end
    subgraph State
        G[(observation-store<br/>persistent KV<br/>RocksDB)]
    end
    subgraph IQ [Interactive Queries]
        H[REST endpoint<br/>/state/observation/{key}]
    end
    subgraph Output
        I[fraud.events]
    end
    A --> B --> C --> D --> E --> F --> I
    C -.- G
    G -.- H
