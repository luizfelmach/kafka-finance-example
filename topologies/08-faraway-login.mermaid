flowchart LR
    subgraph Input
        A[auth.events]
    end
    subgraph Process [Processor API]
        B[FarawayTransformer]
        C{lastLogin exists?}
        D[haversine distance]
        E{speed > 500 km/h?}
        F[forward FraudAlert]
        G[store.put: update lastLogin]
    end
    subgraph State
        H[(last-login-store<br/>persistent KV<br/>RocksDB)]
    end
    subgraph Output
        I[fraud.events]
    end
    A --> B
    B --> C
    C -- sim --> D --> E -- sim --> F --> I
    C -- nao --> G
    E -- nao --> G
    G --> B
    H -.- C
    H -.- G
