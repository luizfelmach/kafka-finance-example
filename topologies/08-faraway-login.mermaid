flowchart LR
    subgraph Input
        A[auth.events]
    end
    subgraph Aggregate [groupByKey + aggregate]
        B[filter: login]
        C[aggregate LoginPair]
        D[(last-login-store<br/>LoginPair<br/>RocksDB)]
    end
    subgraph FlatMap [toStream + flatMap]
        E{previous == null?}
        F[haversine distance]
        G{speed > 900 km/h?}
        H[FraudAlert.farawayLogin]
    end
    subgraph Output
        I[fraud.events]
    end
    A --> B --> C --> D
    D --> E
    E -- sim --> I
    E -- nao --> F --> G
    G -- sim --> H --> I
    G -- nao --> I
