{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "RiskScore",
    "type": "object",
    "properties": {
        "score_id": {
            "type": "string"
        },
        "transaction_id": {
            "type": "string"
        },
        "user_id": {
            "type": "string"
        },
        "risk_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
        },
        "rules_triggered": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "is_anomaly": {
            "type": "boolean"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "score_id",
        "transaction_id",
        "risk_score",
        "timestamp"
    ]
}