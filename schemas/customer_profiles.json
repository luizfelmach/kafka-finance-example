{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CustomerProfile",
    "type": "object",
    "properties": {
        "user_id": {
            "type": "string"
        },
        "avg_transaction_value": {
            "type": "number"
        },
        "trust_level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
        },
        "preferred_categories": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "last_updated": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "user_id",
        "trust_level"
    ]
}