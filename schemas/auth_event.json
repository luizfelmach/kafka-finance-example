{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AuthEvent",
    "type": "object",
    "properties": {
        "event_id": {
            "type": "string"
        },
        "user_id": {
            "type": "string"
        },
        "event_type": {
            "type": "string",
            "enum": [
                "login",
                "logout",
                "password_change",
                "mfa_challenge"
            ]
        },
        "status": {
            "type": "string",
            "enum": [
                "success",
                "fail"
            ]
        },
        "ip_address": {
            "type": "string",
            "format": "ipv4"
        },
        "device_id": {
            "type": "string"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "event_id",
        "user_id",
        "event_type",
        "status",
        "timestamp"
    ]
}