{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "FraudAlert",
    "type": "object",
    "properties": {
        "alert_id": {
            "type": "string"
        },
        "transaction_id": {
            "type": "string"
        },
        "severity": {
            "type": "string",
            "enum": [
                "low",
                "medium",
                "high",
                "critical"
            ]
        },
        "description": {
            "type": "string"
        },
        "suggested_action": {
            "type": "string",
            "enum": [
                "block",
                "review",
                "allow"
            ]
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "alert_id",
        "transaction_id",
        "severity",
        "timestamp"
    ]
}