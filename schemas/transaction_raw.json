{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "TransactionRaw",
    "type": "object",
    "properties": {
        "transaction_id": {
            "type": "string"
        },
        "user_id": {
            "type": "string"
        },
        "amount": {
            "type": "number",
            "minimum": 0
        },
        "currency": {
            "type": "string",
            "pattern": "^[A-Z]{3}$"
        },
        "merchant_id": {
            "type": "string"
        },
        "merchant_category": {
            "type": "string"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "card_type": {
            "type": "string",
            "enum": [
                "credit",
                "debit",
                "virtual"
            ]
        },
        "location": {
            "type": "object",
            "properties": {
                "lat": {
                    "type": "number"
                },
                "lon": {
                    "type": "number"
                },
                "city": {
                    "type": "string"
                }
            }
        }
    },
    "required": [
        "transaction_id",
        "user_id",
        "amount",
        "timestamp"
    ]
}